{
  "version": "2026.06.05.2",
  "updated_at": "2026-06-05",
  "locale": "zh-CN",
  "upstream": {
    "desktop_page": "https://hermes-ai.net/desktop/",
    "agent_repo": "https://github.com/NousResearch/hermes-agent",
    "agent_release": "v2026.5.29.2",
    "agent_version": "0.15.2"
  },
  "packages": {
    "core_tui": "packages/0.15.x/zh-CN/zh-cn.min.json",
    "macos_linux_installer": "install.sh",
    "macos_click_installer": "install.command",
    "windows_installer": "install.ps1"
  },
  "platforms": [
    {
      "id": "windows",
      "label": "Windows",
      "recommended": "powershell",
      "command": "irm https://cdn.jsdelivr.net/gh/fresh-claw/hermes-cn@v2026.06.05.2/install.ps1 | iex",
      "method": "PowerShell 调用官方桌面安装参数，再调用 Git Bash 应用中文增强。",
      "desktop": "生成官方 Hermes.exe，并补 Hermes 核心、TUI、网关和配置。"
    },
    {
      "id": "macos",
      "label": "macOS",
      "recommended": "command_file_or_terminal",
      "command": "curl -fsSL https://cdn.jsdelivr.net/gh/fresh-claw/hermes-cn@v2026.06.05.2/install.sh | bash -s -- --include-desktop",
      "method": "调用官方 --include-desktop 流程生成 Hermes.app，再应用中文增强。",
      "desktop": "生成官方桌面端，并补 Hermes 核心、TUI、网关和配置。"
    },
    {
      "id": "linux",
      "label": "Linux",
      "recommended": "terminal",
      "command": "curl -fsSL https://cdn.jsdelivr.net/gh/fresh-claw/hermes-cn@v2026.06.05.2/install.sh | bash -s -- --include-desktop",
      "method": "调用官方 --include-desktop 流程生成 Linux 桌面端，再应用中文增强。",
      "desktop": "生成官方桌面端，并补 Hermes 核心、TUI、网关和配置。"
    }
  ],
  "localization_surface": [
    "official locale: locales/zh.yaml",
    "CLI: hermes_cli/*.py",
    "TUI: ui-tui/src/**/*.ts and ui-tui/src/**/*.tsx",
    "gateway: gateway/platforms/*.py",
    "ACP: acp_adapter/*.py",
    "platform plugins: plugins/platforms/*",
    "desktop bootstrap: apps/bootstrap-installer",
    "desktop renderer: apps/desktop/src",
    "desktop main process: apps/desktop/electron"
  ],
  "repackage_policy": {
    "default": "patch_after_official_install",
    "reason": "优先调用官方安装器生成桌面端；直接改包会增加启动失败和更新失效风险。",
    "future": "若官方桌面源码发布稳定 tag，再基于源码构建未签名中文测试包。"
  }
}
